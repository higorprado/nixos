# Copy to ./default.nix (untracked) and adjust with Aurelius-specific access policy.
{ lib, ... }:
let
  userName = "your-user";
in
{
  # Optional: split host-private service bindings into ./services.nix.
  # imports = [ ./services.nix ];

  # Optional: make user declarations immutable once fully declared here.
  users.mutableUsers = lib.mkForce false;
  users.users.${userName}.openssh.authorizedKeys.keys = [
    "ssh-ed25519 AAAA... replace-with-real-key"
  ];

  # Optional: if automation requires passwordless sudo, scope it carefully.
  # security.sudo.extraRules = [
  #   {
  #     users = [ userName ];
  #     commands = [
  #       {
  #         command = "/run/current-system/sw/bin/nixos-rebuild";
  #         options = [ "NOPASSWD" ];
  #       }

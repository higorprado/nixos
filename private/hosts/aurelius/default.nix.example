  #       {
  #         command = "/nix/store/*/bin/nix";
  #         options = [ "NOPASSWD" ];
  #       }
  #       {
  #         command = "/run/current-system/sw/bin/nh";
  #         options = [ "NOPASSWD" ];
  #       }
